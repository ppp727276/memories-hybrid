{
  "name": "capricorn",
  "version": "0.1.0",
  "description": "Capricorn v2 — Storage Engine + Intelligence Engine for AI agents",
  "type": "module",
  "main": "./dist/index.mjs",
  "bin": {
    "capricorn": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --outfile dist/cli.mjs --target=node --format=esm && bun build src/index.ts --outfile dist/index.mjs --target=node --format=esm",
    "build:binary": "bun build src/cli/index.ts --compile --outfile dist/capricorn",
    "typecheck": "tsc --noEmit --project tsconfig.check.json",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun run test && bun run typecheck",
    "smoke:phase3": "bun run scripts/smoke-phase3.ts",
    "smoke:phase4": "bun run scripts/smoke-phase4.ts",
    "smoke:osb": "bun run scripts/smoke-osb-bridge.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ppp727276/memories-hybrid"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "yaml": "^2.9.0"
  }
}
