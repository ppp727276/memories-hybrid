{
  "name": "memories-hybrid",
  "version": "1.0.0",
  "description": "Hybrid memory system: OSB vault + Forge enrichment pipeline",
  "type": "module",
  "scripts": {
    "bridge": "tsx bridge/src/bridge.ts",
    "dry-run": "tsx bridge/src/bridge.ts --config bridge-config.json --dry-run",
    "install": "bash scripts/install.sh",
    "backup": "bash scripts/backup.sh",
    "prune": "python scripts/prune-memory.py",
    "typecheck": "tsc --noEmit --project tsconfig.check.json"
  },
  "dependencies": {
    "glob": "^10.4.5",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ppp727276/memories-hybrid"
  },
  "license": "MIT"
}