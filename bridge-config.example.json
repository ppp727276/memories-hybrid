{
  "vaultPath": "~/Documents/second-brain-memory",
  "outputDir": "seed-output",
  "personaTargetPath": "~/Documents/second-brain-memory/Brain/personas/persona-core.md",
  "sessionKey": "hybrid-bridge",
  "pluginConfig": {
    "llm": {
      "enabled": true,
      "provider": "openai-compatible",
      "baseUrl": "http://127.0.0.1:20128/v1",
      "apiKey": "OMNI_ROUTE_API_KEY_HERE",
      "model": "queen/deepseek-v4-pro",
      "maxTokens": 4096,
      "timeoutMs": 120000,
      "disableThinking": "deepseek"
    },
    "embedding": {
      "enabled": true,
      "provider": "openai-compatible",
      "baseUrl": "http://127.0.0.1:20128/v1",
      "apiKey": "",
      "model": "queen/text-embedding-v3"
    },
    "pipeline": {
      "everyNConversations": 1,
      "enableWarmup": true,
      "l1IdleTimeoutSeconds": 600,
      "l2DelayAfterL1Seconds": 10,
      "l2MinIntervalSeconds": 10,
      "l2MaxIntervalSeconds": 60,
      "sessionActiveWindowHours": 24
    },
    "persona": {
      "triggerEveryN": 1,
      "maxScenes": 15,
      "backupCount": 3,
      "sceneBackupCount": 10
    }
  }
}